<div class="section"><div class="container"><h2>Order #<%= order.id %></h2><p><strong>Name:</strong> <%= order.customer_name %></p><p><strong>Phone:</strong> <%= order.phone %></p><p><strong>Address:</strong> <%= order.address %></p><p><strong>Notes:</strong> <%= order.notes || '-' %></p><form method="post" action="/admin/orders/<%= order.id %>/status" class="form-inline"><div class="form-group"><select class="form-control" name="status"><% ['Pending','Processed','Completed','Cancelled'].forEach(function(status) { %><option value="<%= status %>" <%= order.status === status ? 'selected' : '' %>><%= status %></option><% }) %></select></div> <button class="primary-btn">Update Status</button></form><hr><table class="table table-bordered"><thead><tr><th>Product</th><th>Qty</th><th>Price</th></tr></thead><tbody><% items.forEach(function(item) { %><tr><td><%= item.product_name %></td><td><%= item.quantity %></td><td>$<%= Number(item.price).toFixed(2) %></td></tr><% }) %></tbody></table></div></div>
