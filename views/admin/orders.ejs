<div class="section"><div class="container"><h2>Orders</h2><table class="table table-bordered"><thead><tr><th>ID</th><th>Name</th><th>Phone</th><th>Total</th><th>Status</th><th>Action</th></tr></thead><tbody><% orders.forEach(function(order) { %><tr><td>#<%= order.id %></td><td><%= order.customer_name %></td><td><%= order.phone %></td><td>$<%= Number(order.total_amount).toFixed(2) %></td><td><%= order.status %></td><td><a class="btn btn-xs btn-info" href="/admin/orders/<%= order.id %>">Detail</a></td></tr><% }) %></tbody></table></div></div>
