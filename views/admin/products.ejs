<div class="section"><div class="container"><div class="admin-topbar"><h2>Products</h2><a class="primary-btn" href="/admin/products/new">Add Product</a></div><table class="table table-bordered"><thead><tr><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Action</th></tr></thead><tbody><% products.forEach(function(product) { %><tr><td><%= product.name %></td><td><%= product.category_name || '-' %></td><td>$<%= Number(product.price).toFixed(2) %></td><td><%= product.stock %></td><td><a class="btn btn-xs btn-info" href="/admin/products/edit/<%= product.id %>">Edit</a> <form action="/admin/products/delete/<%= product.id %>" method="post" style="display:inline-block"><button class="btn btn-xs btn-danger">Delete</button></form></td></tr><% }) %></tbody></table></div></div>
