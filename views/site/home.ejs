<div class="section">
  <div class="container">
    <div class="row">
      <% categories.slice(0, 3).forEach(function(category) { %>
        <div class="col-md-4 col-xs-6">
          <div class="shop">
            <div class="shop-img gradient-card"></div>
            <div class="shop-body">
              <h3><%= category.name %><br>Collection</h3>
              <a href="/store?category=<%= category.slug %>" class="cta-btn">Shop now <i class="fa fa-arrow-circle-right"></i></a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<div class="section">
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <div class="section-title">
          <h3 class="title">New Products</h3>
        </div>
      </div>
      <div class="col-md-12">
        <div class="products-grid">
          <% latestProducts.forEach(function(product) { %>
            <%- include('../partials/product-card', { product: product }) %>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="section section-grey">
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <div class="section-title">
          <h3 class="title">Featured Products</h3>
        </div>
      </div>
      <div class="col-md-12">
        <div class="products-grid">
          <% featuredProducts.forEach(function(product) { %>
            <%- include('../partials/product-card', { product: product }) %>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>
