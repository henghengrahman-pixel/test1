<div id="breadcrumb" class="section">
  <div class="container"><div class="row"><div class="col-md-12"><ul class="breadcrumb-tree"><li><a href="/">Home</a></li><li class="active">Store</li></ul></div></div></div>
</div>
<div class="section">
  <div class="container">
    <div class="row">
      <div id="aside" class="col-md-3">
        <div class="aside">
          <h3 class="aside-title">Categories</h3>
          <div class="checkbox-filter store-categories">
            <% categories.forEach(function(category) { %>
              <div class="input-checkbox category-link <%= filters.category === category.slug ? 'active' : '' %>">
                <a href="/store?category=<%= category.slug %>"><%= category.name %></a>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
      <div id="store" class="col-md-9">
        <div class="store-filter clearfix">
          <form class="pull-left" method="get" action="/store">
            <input class="input" type="text" name="search" placeholder="Cari produk" value="<%= filters.search %>">
            <button class="primary-btn">Search</button>
          </form>
        </div>
        <div class="products-grid">
          <% if (products.length) { %>
            <% products.forEach(function(product) { %>
              <%- include('../partials/product-card', { product: product }) %>
            <% }) %>
          <% } else { %>
            <div class="empty-state"><h3>No products found</h3><p>Coba kata kunci atau kategori lain.</p></div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
